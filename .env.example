# Supabase — just create a new Supabase project and paste your keys here
# The app works without these (no auth guarding), but auth is ready to go.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only (optional — only needed for admin server actions)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
